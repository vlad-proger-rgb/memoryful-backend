# Local Development Environment Configuration
# Used with docker-compose.local.yml
# All services run locally - no external dependencies

ENVIRONMENT=development
SEED_DB_ON_EMPTY=true

# GCP Settings (local emulators)
GCP_PROJECT_ID=memoryful-dev
USE_SECRET_MANAGER=false
GCP_PUBSUB_EMULATOR_HOST=pubsub-emulator
GCP_PUBSUB_EMULATOR_PORT=8085

# Database (local PostgreSQL container)
POSTGRES_USER=main_user
POSTGRES_PASSWORD=main_password
POSTGRES_PORT=5432
POSTGRES_HOST=db
POSTGRES_DB=main_database
POSTGRES_SSLMODE=prefer

# Authentication (dev keys - not secure)
ACCESS_SECRET_KEY=dev_access_secret_key_change_in_production
REFRESH_SECRET_KEY=dev_refresh_secret_key_change_in_production
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_MINUTES=10080

# RabbitMQ (local container)
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_WEB_PORT=15673
RABBITMQ_DEFAULT_USER=guest
RABBITMQ_DEFAULT_PASS=guest

# Redis (local container)
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=dev_redis_password
REDIS_SSL=false

# Flower (Celery monitoring)
FLOWER_PORT=5555

# Email (Resend - use your dev API key)
RESEND_API_KEY=your_resend_api_key_here
MAIL_FROM=dev@noreply.memory-ful.com
MAIL_FROM_NAME=Memoryful Dev

# CORS (local frontend)
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:5173,http://127.0.0.1:5173
ALLOW_CREDENTIALS=true
ALLOWED_METHODS=GET,POST,PUT,DELETE,OPTIONS
ALLOWED_HEADERS=Content-Type,Authorization,Set-Cookie

# Trusted Emails
TRUSTED_EMAILS=dev@example.com,your-email@example.com,vlad0307b@gmail.com

# Storage (local MinIO container)
S3_ENDPOINT_URL=http://minio:9000
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_REGION=us-east-1
S3_BUCKET=memoryful
S3_PUBLIC_BASE_URL=http://localhost:9000

# LLM Settings (local Ollama)
LLM_PROVIDER=local
OPENAI_TEMPERATURE=0.4
OPENAI_MODEL=gpt-4o-mini
LOCAL_LLM_BASE_URL=http://ollama:11434/v1
LOCAL_LLM_MODEL=llama3.1
LOCAL_LLM_API_KEY=local
ANTHROPIC_MODEL=claude-3-5-sonnet-20240620

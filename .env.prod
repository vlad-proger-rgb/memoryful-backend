# Production Environment Configuration
# Copy this file to .env and fill in your actual values
# Secrets (DB credentials, API keys, etc.) are fetched from GCP Secret Manager

ENVIRONMENT=production
SEED_DB_ON_EMPTY=false

# GCP Settings
GCP_PROJECT_ID=memoryful
USE_SECRET_MANAGER=true
GCP_CREDENTIALS_PATH=/app/secrets/service-account.json

# GCP PubSub (Celery Broker)
GCP_PUBSUB_PROJECT_ID=memoryful

# Database (connection details - credentials from Secret Manager)
POSTGRES_PORT=5432
POSTGRES_DB=memoryful
POSTGRES_SSLMODE=require

# Redis (connection details - credentials from Secret Manager)
REDIS_PORT=6379
REDIS_DB=0
REDIS_SSL=true

# Email
MAIL_FROM_NAME=Memoryful

# CORS
ALLOWED_ORIGINS=https://www.memory-ful.com,https://memory-ful.com
ALLOW_CREDENTIALS=true
ALLOWED_METHODS=GET,POST,PUT,DELETE,OPTIONS
ALLOWED_HEADERS=Content-Type,Authorization,Set-Cookie

# Trusted Emails
TRUSTED_EMAILS=your-email@example.com

# Storage (GCS)
S3_ENDPOINT_URL=https://storage.googleapis.com
S3_REGION=europe-central2
S3_BUCKET=memoryful
S3_PUBLIC_BASE_URL=https://storage.googleapis.com

# Token Expiration
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_MINUTES=10080

# LLM Settings
LLM_PROVIDER=openai
OPENAI_MODEL=gpt-4o-mini
OPENAI_TEMPERATURE=0.4
ANTHROPIC_MODEL=claude-3-5-sonnet-20240620

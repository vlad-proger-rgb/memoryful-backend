# Production Environment Configuration
# Used with docker-compose.yml

ENVIRONMENT=production
SEED_DB_ON_EMPTY=false

# Database
POSTGRES_USER=main_user
POSTGRES_PASSWORD=main_password
POSTGRES_PORT=5432
POSTGRES_HOST=db_prod
POSTGRES_DB=main_database

# Authentication
ACCESS_SECRET_KEY=YOUR_ACCESS_SECRET_KEY
REFRESH_SECRET_KEY=YOUR_REFRESH_SECRET_KEY
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_MINUTES=10080

# RabbitMQ
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_WEB_PORT=15673
RABBITMQ_DEFAULT_USER=guest
RABBITMQ_DEFAULT_PASS=guest

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0

# Flower
FLOWER_PORT=5555

# Mail
MAIL_USERNAME=example@gmail.com
MAIL_PASSWORD=password
MAIL_FROM=example@gmail.com
MAIL_PORT=587
MAIL_SERVER=smtp.gmail.com
MAIL_FROM_NAME=Memoryful

# CORS
ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com
ALLOW_CREDENTIALS=true
ALLOWED_METHODS=GET,POST,PUT,DELETE,OPTIONS
ALLOWED_HEADERS=Content-Type,Authorization,Set-Cookie

# Trusted Emails
TRUSTED_EMAILS=example@gmail.com,example2@gmail.com

# GCP Settings
GCP_PROJECT_ID=memoryful
USE_SECRET_MANAGER=true

# Storage
S3_REGION=europe-central2
S3_BUCKET=memoryful

# LLM Settings
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_TEMPERATURE=0.4
LLM_PROVIDER=openai
ANTHROPIC_MODEL=claude-3-5-sonnet-20240620
